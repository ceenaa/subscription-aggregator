PORT=2082
HOST=0.0.0.0
REQUEST_TIMEOUT_MS=15000
SQLITE_DB_PATH=./data/subscription-aggregator.sqlite3
XRAY_BIN=./Xray-macos-arm64-v8a/xray

FIRST_SUBSCRIPTION_BASE_URL=https://example.com/sub
FIRST_SUBSCRIPTION_PROXY=xray
SECOND_SUBSCRIPTION_BASE_URL=https://example.com/sub

SECOND_SUBSCRIPTION_PROXY=direct
XRAY_OUTBOUND_LINK='vless://uuid@example.com:443?type=ws&encryption=none&path=%2F&host=example.com&security=tls&fp=chrome&alpn=h2%2Chttp%2F1.1&sni=example.com#name'

HTTPS_ENABLED=false
HTTPS_KEY_PATH=/absolute/path/to/privkey.pem
HTTPS_CERT_PATH=/absolute/path/to/fullchain.pem
HTTPS_HSTS_ENABLED=true
PUBLIC_BASE_URL=https://your-domain.com
HTTPS_HSTS_MAX_AGE=15552000

TRUST_PROXY=false
CORS_ORIGIN=https://app.example.com,https://admin.example.com
WORKER_CONCURRENCY=5

ADMIN_USERNAME=
ADMIN_PASSWORD=
